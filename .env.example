# Server bind address. Keep real provider credentials only in an ignored .env file.
BIND_ADDR=0.0.0.0:8000
# Host port published by the Docker Compose Nginx edge proxy.
APP_PORT=8080
# Optional. Set this only when catalog setup needs bearer-token protection.
ADMIN_SETUP_TOKEN=
COOKIE_SECURE=false

# Optional. Set these to your local user/group IDs when Docker cannot read the
# cached Space-Track catalog under data/cache/space-track.
HOST_UID=1000
HOST_GID=1000

# Optional browser override when the API is not same-origin proxied through Vite or Compose.
VITE_API_BASE=http://localhost:8000

# Optional alternative to entering credentials in the server settings dialog.
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# Read-only runtime output produced by the explicit space-card-enrich CLI.
SPACE_CARDS_DIR=data/generated/space-cards

# Optional airport-cache overrides. Public OurAirports and FAA sources refresh
# after 24 hours by default. Pin FAA_NASR_APT_URL only for a specific cycle.
AIRPORT_CACHE_DIR=data/cache/airports
AIRPORT_REFRESH_MAX_AGE_SECONDS=86400
FAA_NASR_APT_URL=
